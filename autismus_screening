<script>
function asToggle(id) {
  var card = document.getElementById('as-' + id);
  var body = document.getElementById('as-body-' + id);
  var btn  = document.getElementById('as-btn-' + id);
  var isOpen = card.classList.contains('as-open');
  document.querySelectorAll('.as-card').forEach(function(c) {
    c.classList.remove('as-open');
    var b = c.querySelector('.as-btn');
    var bd = c.querySelector('.as-body');
    if (b) b.textContent = '+';
    if (bd) bd.style.display = 'none';
  });
  if (!isOpen) {
    card.classList.add('as-open');
    btn.textContent = '–';
    body.style.display = 'block';
  }
  setTimeout(sendHeight, 50);
  setTimeout(sendHeight, 400);
}
function sendHeight() {
  var root = document.querySelector('.as-root');
  var h = root ? root.getBoundingClientRect().height : document.body.scrollHeight;
  window.parent.postMessage({ iframeHeight: Math.ceil(h) }, '*');
}
window.addEventListener('load', function() { setTimeout(sendHeight, 200); });
window.addEventListener('resize', sendHeight);
</script>
